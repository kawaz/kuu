{
  "why": "DR-113 §1/§4.3/§4.4 の path、depth、origin、query-error を固定する。help_query は installer の宣言層寄与後を読み、global option の子孫コピーを origin 付きで返す。depth all は command entry の scope に再帰 model を埋め込む。",
  "query": "help",
  "definition": {
    "name": "prog",
    "options": [
      {"name": "help", "type": "help", "long": true, "global": true, "help": "show help"}
    ],
    "commands": [
      {
        "type": "command",
        "name": "remote",
        "help": "manage remotes",
        "commands": [
          {
            "type": "command",
            "name": "add",
            "help": "add a remote",
            "positionals": [
              {"name": "url", "type": "string", "value_name": "URL", "help": "remote url"}
            ]
          }
        ]
      },
      {"alias": "remote", "type": "command", "name": "r"}
    ]
  },
  "cases": [
    {
      "id": "root-lists-subcommands-one-layer",
      "why": "DR-113 §4.4 により depth 既定 scope では remote を aliases 付き一覧 entry として返すが、子 scope は埋め込まない。root 自身の help entry は local origin である。",
      "expect": {
        "outcome": "help",
        "command_path": ["prog"],
        "usage": {"has_options": true, "has_subcommands": true},
        "commands": [
          {"name": "remote", "aliases": ["r"], "help": "manage remotes", "hidden": false, "deprecated": false, "origin": "local"}
        ],
        "options": [
          {"spellings": ["--help"], "help": "show help", "hidden": false, "deprecated": false, "origin": "local"}
        ],
        "help_entry": "--help"
      }
    },
    {
      "id": "nested-path-shows-global-copy-origin",
      "why": "DR-113 §1/§4.3 により path remote/add は孫 scope を選択する。global help の宣言的コピーは定義元 root の command_path を declared_at に持つ global origin となる。",
      "path": ["remote", "add"],
      "expect": {
        "outcome": "help",
        "command_path": ["prog", "remote", "add"],
        "usage": {"has_options": true, "positionals": [
          {"value_structure": {"single": {"value_name": "URL", "type": "string"}}}
        ]},
        "description": "add a remote",
        "options": [
          {"spellings": ["--help"], "help": "show help", "hidden": false, "deprecated": false, "origin": {"kind": "global", "declared_at": ["prog"]}}
        ],
        "positionals": [
          {"value_structure": {"single": {"value_name": "URL", "type": "string"}}, "help": "remote url", "hidden": false, "deprecated": false}
        ],
        "help_entry": "--help"
      }
    },
    {
      "id": "depth-all-embeds-recursive-scopes",
      "why": "DR-113 §4.4 により depth all は root の command entry に remote scope、その子 command entry に add scope を再帰埋め込みする。各子 scope は global help copy の origin を保持する。",
      "depth": "all",
      "expect": {
        "outcome": "help",
        "command_path": ["prog"],
        "usage": {"has_options": true, "has_subcommands": true},
        "commands": [
          {
            "name": "remote",
            "aliases": ["r"],
            "help": "manage remotes",
            "hidden": false,
            "deprecated": false,
            "origin": "local",
            "scope": {
              "outcome": "help",
              "command_path": ["prog", "remote"],
              "usage": {"has_options": true, "has_subcommands": true},
              "description": "manage remotes",
              "commands": [
                {
                  "name": "add",
                  "help": "add a remote",
                  "hidden": false,
                  "deprecated": false,
                  "origin": "local",
                  "scope": {
                    "outcome": "help",
                    "command_path": ["prog", "remote", "add"],
                    "usage": {"has_options": true, "positionals": [
                      {"value_structure": {"single": {"value_name": "URL", "type": "string"}}}
                    ]},
                    "description": "add a remote",
                    "options": [
                      {"spellings": ["--help"], "help": "show help", "hidden": false, "deprecated": false, "origin": {"kind": "global", "declared_at": ["prog"]}}
                    ],
                    "positionals": [
                      {"value_structure": {"single": {"value_name": "URL", "type": "string"}}, "help": "remote url", "hidden": false, "deprecated": false}
                    ],
                    "help_entry": "--help"
                  }
                }
              ],
              "options": [
                {"spellings": ["--help"], "help": "show help", "hidden": false, "deprecated": false, "origin": {"kind": "global", "declared_at": ["prog"]}}
              ],
              "help_entry": "--help"
            }
          }
        ],
        "options": [
          {"spellings": ["--help"], "help": "show help", "hidden": false, "deprecated": false, "origin": "local"}
        ],
        "help_entry": "--help"
      }
    },
    {
      "id": "absent-path-is-query-error",
      "why": "DR-113 §1/§9 により合法な definition に存在しない path nosuch は、definition-error でなく help query 入力の query-error absent-path を返す。",
      "path": ["nosuch"],
      "expect": {"outcome": "query-error", "errors": [{"kind": "absent-path"}]}
    }
  ]
}
