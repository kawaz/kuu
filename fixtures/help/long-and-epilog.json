{
  "why": "DR-113 §7.1/§4.4 に従い help、help_long、help_epilog は独立した表示素材として model に射影し、未設定側を相互フォールバックで複製しない。",
  "query": "help",
  "definition": {
    "name": "tool",
    "help": "short description",
    "help_long": "Long description with full detail.\nMultiple lines are just string content.",
    "help_epilog": "Report bugs to <bugs@example.com>.",
    "options": [
      {"name": "short-only", "type": "flag", "long": true, "help": "has help only"},
      {"name": "long-only", "type": "flag", "long": true, "help_long": "has help_long only"},
      {"name": "both", "type": "flag", "long": true, "help": "short text", "help_long": "long text"}
    ]
  },
  "cases": [{
    "id": "no-fallback-materials-as-declared",
    "why": "DR-113 §7.1/§4.4 により scope と各 option は宣言された短文・長文だけを対応する席へ載せる。フォールバックと出し分けは renderer policy である。",
    "expect": {
      "outcome": "help",
      "command_path": ["tool"],
      "usage": {"has_options": true},
      "description": "short description",
      "description_long": "Long description with full detail.\nMultiple lines are just string content.",
      "epilog": "Report bugs to <bugs@example.com>.",
      "options": [
        {"spellings": ["--short-only"], "help": "has help only", "hidden": false, "deprecated": false, "origin": "local"},
        {"spellings": ["--long-only"], "help_long": "has help_long only", "hidden": false, "deprecated": false, "origin": "local"},
        {"spellings": ["--both"], "help": "short text", "help_long": "long text", "hidden": false, "deprecated": false, "origin": "local"}
      ]
    }
  }]
}
