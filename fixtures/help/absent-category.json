{
  "why": "DR-113 §1 の named category 選択と query-error を pin する。named は指定グループ宣言 entry と所属 entry だけに model を絞り、不在 named category は help query 固有の absent-category となる。",
  "query": "help",
  "definition": {"options": [
    {"help_group_name": "net", "help_group_title": "Network options"},
    {"name": "port", "type": "number", "long": true, "value_name": "PORT", "help_group_name": "net", "help": "listen port"},
    {"name": "verbose", "type": "flag", "long": true, "help": "verbose output"},
    {"name": "secret", "type": "flag", "long": true, "hidden": true, "help": "internal option"}
  ]},
  "cases": [
    {
      "id": "named-mode-filters-to-selected-group",
      "why": "DR-113 §1 により category_mode named:net は net のグループ宣言と所属する port だけを返し、非所属の verbose/secret を除外する。",
      "category_mode": {"named": "net"},
      "expect": {"outcome": "help", "command_path": [], "usage": {"has_options": true}, "options": [
        {"group": {"name": "net", "title": "Network options"}},
        {"spellings": ["--port"], "value_structure": {"single": {"value_name": "PORT", "type": "number"}}, "help_group_name": "net", "help": "listen port", "hidden": false, "deprecated": false, "origin": "local"}
      ]}
    },
    {
      "id": "absent-named-category-is-query-error",
      "why": "DR-113 §1/§9 により合法な definition に存在しない named category nosuch は definition-error でなく query-error absent-category を返す。",
      "category_mode": {"named": "nosuch"},
      "expect": {"outcome": "query-error", "errors": [{"kind": "absent-category"}]}
    }
  ]
}
