{
  "why": "同一 target への複数 help_after は DR-113 §8.2 に従い定義順で target 直後へ並ぶ。help_query は並べ替え済み options 列を、各 entry の表示素材と origin を保った構造化 model として返す。",
  "query": "help",
  "definition": {"options": [
    {"name": "a", "type": "flag", "long": true, "help": "target"},
    {"name": "x", "type": "flag", "long": true, "help": "unrelated tail"},
    {"name": "b", "type": "flag", "long": true, "help_after": "a", "help": "first after"},
    {"name": "c", "type": "flag", "long": true, "help_after": "a", "help": "second after"}
  ]},
  "cases": [{
    "id": "multiple-after-same-target-definition-order",
    "why": "DR-113 §8.2 により b と c は同じ target a の直後へ定義順で移る。結果は a, b, c, x となり、名前順や逆順へ並べ替えない。",
    "expect": {"outcome": "help", "command_path": [], "usage": {"has_options": true}, "options": [
      {"spellings": ["--a"], "help": "target", "hidden": false, "deprecated": false, "origin": "local"},
      {"spellings": ["--b"], "help": "first after", "hidden": false, "deprecated": false, "origin": "local"},
      {"spellings": ["--c"], "help": "second after", "hidden": false, "deprecated": false, "origin": "local"},
      {"spellings": ["--x"], "help": "unrelated tail", "hidden": false, "deprecated": false, "origin": "local"}
    ]}
  }]
}
