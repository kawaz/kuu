{
  "why": "DR-113 §4 の help model 基本形を固定する。単一値 option/positional は value_structure.single へ射影し、usage positional は進行素材だけ、詳細 positional は help と可視性メタを持つ別 entry とする。required / multiple は注記素材として保持する。",
  "query": "help",
  "definition": {
    "name": "prog",
    "help": "Serve files over HTTP",
    "options": [
      {"name": "port", "type": "number", "long": true, "short": "p", "env": "PORT", "default": 8080, "display_name": "Listen port", "value_name": "PORT", "help": "listen port"},
      {"name": "token", "type": "string", "long": true, "value_name": "TOKEN", "required": true, "help": "required token"},
      {"name": "tag", "type": "string", "long": true, "value_name": "TAG", "multiple": "append", "help": "repeatable tag"},
      {"name": "help", "type": "help", "long": true, "help": "show help"}
    ],
    "positionals": [
      {"name": "file", "type": "string", "value_name": "FILE", "help": "input file"}
    ]
  },
  "cases": [{
    "id": "root-scope-typed-model",
    "why": "DR-113 §4.4 により port/file の型を single node に保持し、token の required:true と tag の multiple:true を option 注記素材として返す。usage positional は value_structure だけを持つ。",
    "expect": {
      "outcome": "help",
      "command_path": ["prog"],
      "usage": {"has_options": true, "positionals": [
        {"value_structure": {"single": {"value_name": "FILE", "type": "string"}}}
      ]},
      "description": "Serve files over HTTP",
      "options": [
        {"spellings": ["--port", "-p"], "value_structure": {"single": {"value_name": "PORT", "type": "number"}}, "display_name": "Listen port", "help": "listen port", "default": 8080, "env": "PORT", "hidden": false, "deprecated": false, "origin": "local"},
        {"spellings": ["--token"], "value_structure": {"single": {"value_name": "TOKEN", "type": "string"}}, "help": "required token", "required": true, "hidden": false, "deprecated": false, "origin": "local"},
        {"spellings": ["--tag"], "value_structure": {"single": {"value_name": "TAG", "type": "string"}}, "help": "repeatable tag", "multiple": true, "hidden": false, "deprecated": false, "origin": "local"},
        {"spellings": ["--help"], "help": "show help", "hidden": false, "deprecated": false, "origin": "local"}
      ],
      "positionals": [
        {"value_structure": {"single": {"value_name": "FILE", "type": "string"}}, "help": "input file", "hidden": false, "deprecated": false}
      ],
      "help_entry": "--help"
    }
  }]
}
