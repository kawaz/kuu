{
  "why": "count preset の `long:true` は DR-114 の canonical 展開で `cell_fns` の `incr` 呼び出しになる。`incr` は発火直前の `FnCtx.old` から old + 1 の Value を返し、その Value が通常の set operand として cell へ適用される。default 0 から long/short の発火順に 1, 2, 3 と更新され、effects は各時点の set operation を保持する。",
  "query": "parse",
  "definition": {
    "options": [
      {"name": "verbose", "type": "count", "long": true, "short": "v"}
    ]
  },
  "cases": [
    {
      "id": "no-fire-default-zero",
      "why": "未発火時は count preset の default 0 が present となる。default 由来値は CLI effect へ載らず、result と sources で確認する。",
      "args": [],
      "expect": {
        "outcome": "success",
        "effects": [],
        "result": {"verbose": 0},
        "sources": {"verbose": "default"}
      }
    },
    {
      "id": "long-single-fire-one",
      "why": "count preset が `long:true` を `cell_fns` の `incr` 呼び出しへ canonical 展開する。`--verbose` の発火で old=0 から Value 1 を返し、set operand 1 として cell へ適用される。",
      "args": ["--verbose"],
      "expect": {
        "outcome": "success",
        "effects": [
          {"entity": "verbose", "op": "set", "operand": 1, "source": "cli"}
        ],
        "result": {"verbose": 1},
        "sources": {"verbose": "cli"}
      }
    },
    {
      "id": "long-double-fire-two",
      "why": "`--verbose --verbose` は `incr` を発火順に2回呼び、old=0→1、old=1→2 の Value を set operand 1, 2 として積む。",
      "args": ["--verbose", "--verbose"],
      "expect": {
        "outcome": "success",
        "effects": [
          {"entity": "verbose", "op": "set", "operand": 1, "source": "cli"},
          {"entity": "verbose", "op": "set", "operand": 2, "source": "cli"}
        ],
        "result": {"verbose": 2},
        "sources": {"verbose": "cli"}
      }
    },
    {
      "id": "short-cluster-triple-fire-three",
      "why": "short cluster `-vvv` は3発火を生み、long と同じ `incr` cell fn を順に呼ぶ。effects は set operand 1, 2, 3、最終値は3となる。",
      "args": ["-vvv"],
      "expect": {
        "outcome": "success",
        "effects": [
          {"entity": "verbose", "op": "set", "operand": 1, "source": "cli"},
          {"entity": "verbose", "op": "set", "operand": 2, "source": "cli"},
          {"entity": "verbose", "op": "set", "operand": 3, "source": "cli"}
        ],
        "result": {"verbose": 3},
        "sources": {"verbose": "cli"}
      }
    }
  ]
}
