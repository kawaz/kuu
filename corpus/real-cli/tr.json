{
  "why": "tr (BSD, macOS 実機 `tr [-Ccsu] string1 [string2]`, `tr [-Ccu] -d string1`) のプローブ: bool flag 群 + 必須 string1 + モード従属の string2 (削除モード -d では string2 不要)。プローブ対象 = flag によって positional arity が変わる CLI を素直な optional で近似できるか。既知の限界 (issue 候補): 実機 tr は -d 指定時 string2 を取らず (余ると誤り)、非 -d 時は string2 必須。この『flag が positional の必須性を反転させる』依存は kuu の静的 positional 宣言では表せず、string2 を一律 optional にする近似になる (-d なしで string2 省略も通ってしまう)。",
  "query": "parse",
  "definition": {
    "options": [
      {"name": "complement", "type": "flag", "short": "c"},
      {"name": "squeeze", "type": "flag", "short": "s"},
      {"name": "delete", "type": "flag", "short": "d"}
    ],
    "positionals": [
      {"name": "set1", "type": "string", "required": true},
      {"name": "set2", "type": "string", "optional": true}
    ]
  },
  "cases": [
    {
      "id": "translate-two-sets",
      "why": "`tr a-z A-Z` (実機は小文字→大文字)。set1=\"a-z\" required、set2=[\"A-Z\"] optional。flag 全 false。標準の 2 集合変換。",
      "args": ["a-z", "A-Z"],
      "expect": {
        "outcome": "success",
        "effects": [
          {"entity": "set1", "op": "set", "operand": "a-z", "source": "cli"},
          {"entity": "set2", "op": "set", "operand": "A-Z", "source": "cli"}
        ],
        "result": {"complement": false, "squeeze": false, "delete": false, "set1": "a-z", "set2": ["A-Z"]}
      }
    },
    {
      "id": "delete-mode",
      "why": "`tr -d aeiou` (実機は母音削除)。-d flag 発火、set1=\"aeiou\"、set2 省略 → optional 0 個 `[]`。削除モードは 1 集合のみという実機挙動を近似 (set2 空で成立)。",
      "args": ["-d", "aeiou"],
      "expect": {
        "outcome": "success",
        "effects": [
          {"entity": "delete", "op": "set", "operand": true, "source": "cli"},
          {"entity": "set1", "op": "set", "operand": "aeiou", "source": "cli"}
        ],
        "result": {"complement": false, "squeeze": false, "delete": true, "set1": "aeiou", "set2": []}
      }
    },
    {
      "id": "squeeze-spaces",
      "why": "`tr -s ' '` (実機は連続空白を 1 個に圧縮、squeeze は 1 集合でも動く)。-s flag、set1=\" \"、set2 省略。squeeze も set2 任意という近似を固定。",
      "args": ["-s", " "],
      "expect": {
        "outcome": "success",
        "effects": [
          {"entity": "squeeze", "op": "set", "operand": true, "source": "cli"},
          {"entity": "set1", "op": "set", "operand": " ", "source": "cli"}
        ],
        "result": {"complement": false, "squeeze": true, "delete": false, "set1": " ", "set2": []}
      }
    }
  ]
}
