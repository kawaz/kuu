{
  "why": "mkdir (BSD, macOS 実機 `mkdir [-pv] [-m mode] directory_name ...`) のプローブ: bool flag 2 個 + 値オプション 1 個 (-m mode) + 必須可変長 positional (1 個以上)。プローブ対象 = repeat {min:1} の必須ディレクトリ列と、値オプション -m の共存。mode は 8 進表記 (755 等) だが kuu の canonical number は先頭 0 を decimal 扱い (DR-074) なので mode は string で受け取りアプリが 8 進解釈する (型の領分の外)。",
  "query": "parse",
  "definition": {
    "options": [
      {"name": "parents", "type": "flag", "short": "p"},
      {"name": "verbose", "type": "flag", "short": "v"},
      {"name": "mode", "type": "string", "short": "m"}
    ],
    "positionals": [
      {"name": "directories", "type": "string", "repeat": {"min": 1}}
    ]
  },
  "cases": [
    {
      "id": "parents-single-dir",
      "why": "`mkdir -p a/b/c` (実機は中間も作る)。-p flag 発火、a/b/c が directories に 1 個落ちる。verbose 未発火 false、mode absent (default なし値オプション)。",
      "argv": ["-p", "a/b/c"],
      "expect": {
        "outcome": "success",
        "effects": [
          {"entity": "parents", "op": "set", "operand": true, "source": "cli"},
          {"entity": "directories", "op": "set", "operand": "a/b/c", "source": "cli"}
        ],
        "result": {"parents": true, "verbose": false, "directories": ["a/b/c"]}
      }
    },
    {
      "id": "mode-value",
      "why": "`mkdir -m 755 dir` (実機は権限 755 で作成)。-m が string \"755\" を値バインド (8 進解釈はアプリ)。-p/-v 未発火。",
      "argv": ["-m", "755", "dir"],
      "expect": {
        "outcome": "success",
        "effects": [
          {"entity": "mode", "op": "set", "operand": "755", "source": "cli"},
          {"entity": "directories", "op": "set", "operand": "dir", "source": "cli"}
        ],
        "result": {"mode": "755", "parents": false, "verbose": false, "directories": ["dir"]}
      }
    },
    {
      "id": "multiple-dirs",
      "why": "`mkdir dir1 dir2` (実機は両方作成)。repeat {min:1} が 2 トークンを `[dir1,dir2]` に畳む。flag 全て未発火。",
      "argv": ["dir1", "dir2"],
      "expect": {
        "outcome": "success",
        "effects": [
          {"entity": "directories", "op": "set", "operand": "dir1", "source": "cli"},
          {"entity": "directories", "op": "set", "operand": "dir2", "source": "cli"}
        ],
        "result": {"parents": false, "verbose": false, "directories": ["dir1", "dir2"]}
      }
    },
    {
      "id": "no-dir-fails",
      "why": "`mkdir` 単体は operand 不足 (実機 usage エラー)。directories は repeat {min:1} の 1 個目必須 head がトークンを得られず missing_operand、argv_pos=0。",
      "argv": [],
      "expect": {
        "outcome": "failure",
        "errors": [{"element": "directories", "argv_pos": 0, "kind": "parse", "reason": "missing_operand"}]
      }
    }
  ]
}
